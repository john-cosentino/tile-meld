{
  "name": "@tile-meld/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/db/migrate-cli.ts up",
    "migrate:down": "tsx src/db/migrate-cli.ts down",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "node scripts/build.mjs",
    "start": "node dist/index.js",
    "start:migrate": "node dist/migrate-cli.js up"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^10.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@tile-meld/engine": "workspace:*",
    "@tile-meld/shared": "workspace:*",
    "fastify": "^5.2.1",
    "fastify-type-provider-zod": "^4.0.2",
    "kysely": "^0.28.17",
    "pg": "^8.13.1",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.25.0",
    "socket.io-client": "^4.8.3"
  }
}
