# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3000

# PostgreSQL (matches docker-compose.yml defaults for local dev)
POSTGRES_USER=tilemeld
POSTGRES_PASSWORD=tilemeld
POSTGRES_DB=tilemeld
DATABASE_URL=postgres://tilemeld:tilemeld@localhost:5432/tilemeld

# Session tokens are hashed with a keyed HMAC (SHA-256) for deterministic,
# indexed lookup -- NOT Argon2id (Argon2id is reserved for the long-term
# recovery secret, where deterministic lookup is not required). Generate with:
#   openssl rand -hex 32
SESSION_TOKEN_HMAC_SECRET=

# Allowed CORS origin for the web client (e.g. http://localhost:5173 in
# dev). Leave unset to allow same-origin requests only.
CORS_ORIGIN=

# Web Push (VAPID) -- optional; a progressive enhancement (in-app
# notifications work fully without it). Leave all three blank to disable
# push entirely, or generate a keypair with:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Play vs Computer (the single-player computer opponent). ENABLED BY DEFAULT:
# leave ENABLE_COMPUTER_OPPONENT unset (or "true") for the normal, feature-on
# configuration. Set it to "false" as an operational kill switch -- that blocks
# only NEW "Play vs Computer" room creation; in-flight games keep running and
# recover normally.
ENABLE_COMPUTER_OPPONENT=true

# How long (ms) the computer waits before taking its turn, after a turn is
# handed to it. Purely a UX latency knob (the human sees their turn finish and
# the "Computer is playing" state before the bot moves); it is NOT a
# correctness mechanism -- durable recovery does not depend on it. Optional;
# defaults to ~1000ms when unset. Range 0-60000.
BOT_TURN_DELAY_MS=1000
