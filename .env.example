# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3000

# PostgreSQL (matches docker-compose.yml defaults for local dev)
POSTGRES_USER=tilemeld
POSTGRES_PASSWORD=tilemeld
POSTGRES_DB=tilemeld
DATABASE_URL=postgres://tilemeld:tilemeld@localhost:5432/tilemeld

# Session tokens are hashed with a keyed HMAC (SHA-256) for deterministic,
# indexed lookup -- NOT Argon2id (Argon2id is reserved for the long-term
# recovery secret, where deterministic lookup is not required). Generate with:
#   openssl rand -hex 32
SESSION_TOKEN_HMAC_SECRET=

# Web Push (VAPID) -- generated once per deployment, added in Phase 7.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
